{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "flow",
  "version": "1.5.0",
  "identifier": "lumorez",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Flow",
        "width": 1354,
        "height": 260,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "skipTaskbar": true,
        "center": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$LOCALAPPDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMwODBEMDc2Mzk5NzkyQQpSV1FxZVpsakJ3MElBd2pFS0s2Zm0rd2prdnM5NW1XakJCcVJkcGpkeHdEdUNZbnhDbUpsd0pOTAo=",
      "endpoints": [
        "https://github.com/LumoRez07/Flow/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
